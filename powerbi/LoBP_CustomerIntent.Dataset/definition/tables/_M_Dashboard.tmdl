		sourceColumn: Column1

		annotation SummarizationSetBy = Automatic

	partition _M_Dashboard = m
		mode: import
		source =
				let
				    Source = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText("i44FAA==", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text)) in type table [ Column1 = _t ])
				in
				    Source

